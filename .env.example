# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
DB_NAME=
COLLECTION_NAME=

# ── Authentication ─────────────────────────────────────────────────────────────
# Must match JWT_SECRET in the auth microservice
JWT_SECRET=your-jwt-secret-here

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=
QUERY_MODEL=
JUDGE_MODEL=

# ── Groq (optional — required only when PROVIDER=groq) ────────────────────────
GROQ_API_KEY=gsk_...
GROQ_QUERY_MODEL=
GROQ_JUDGE_MODEL=

# ── Vector Search ──────────────────────────────────────────────────────────────
VECTOR_INDEX=
CANDIDATES=
VECTOR_SCORE_THRESHOLD=

# ── Provider ───────────────────────────────────────────────────────────────────
# Active LLM provider: "openai" or "groq"
PROVIDER=

# ── Langfuse (observability) ───────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com
